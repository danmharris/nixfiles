{
    "extends": [
        "config:recommended",
        ":semanticCommits",
        "helpers:pinGitHubActionDigests"
    ],
    "nix": {
        "enabled": true
    },
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["* * * * 0"]
    },
    "packageRules": [
        {
            "matchDepTypes": ["action"],
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": true,
            "automergeType": "branch",
            "ignoreTests": true
        },
        {
            "matchUpdateTypes": ["lockFileMaintenance"],
            "automerge": true,
            "automergeType": "branch",
            "ignoreTests": true
        }
    ]
}
